# ═══════════════════════════════════════════════════════════════════
#  UAV Ground Station — Environment Variables
#  Copy this file to .env and adjust for your deployment.
# ═══════════════════════════════════════════════════════════════════

# ── Network ─────────────────────────────────────────────────────────
# Bind host for the web server.
# Use 0.0.0.0 to listen on all interfaces (LAN + Tailscale).
HOST=0.0.0.0

# HTTP / WebSocket port for the web interface.
WEB_PORT=8000

# UDP port on which video packets are received from the UAV.
# Must match the sender-side PORT setting.
UDP_PORT=5000

# ── Video ─────────────────────────────────────────────────────────
# Maximum frames per second forwarded over WebSocket to browsers.
# Lower this if server CPU is high. The UDP receiver always runs at
# full stream rate regardless of this setting.
VIDEO_FPS_LIMIT=30

# JPEG re-encode quality (1–100). Higher = better quality, more bandwidth.
VIDEO_JPEG_QUALITY=80

# Maximum simultaneous video WebSocket clients.
VIDEO_MAX_CLIENTS=10

# ── Tailscale ────────────────────────────────────────────────────
# Set to true when the server is reachable via Tailscale.
# Enables Tailscale-specific logging; does not change network behaviour.
TAILSCALE_ENABLED=false

# ── Logging ─────────────────────────────────────────────────────
# Python logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── Telemetry ──────────────────────────────────────────────────
# Simulated telemetry publish rate in Hz (real MAVLink ignores this).
TELEMETRY_HZ=5.0

# ── Snapshots ──────────────────────────────────────────────────
# Directory where browser-triggered snapshots are saved server-side.
SNAPSHOT_DIR=snapshots
